using Gtk 4.0;
using Adw 1;

template $TestInstallerDisksPage: $ReadySetBasePage {
  title-header: "Disks";
  title-icon-name: "drive-multidisk-symbolic";
  is-ready: true;

  content: Adw.Clamp {
    $ReadySetStatusPage {
      title: "Disks";
      description: "Select the disks to install on";
    }
  };
}
