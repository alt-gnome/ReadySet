polkit.addRule(function(action, subject) {
    if (!subject.isInGroup('ready-set') && !subject.isInGroup('gnome-initial-setup'))
        return;

    var actionMatches = action.id === "org.freedesktop.policykit.exec" &&
         action.lookup("program") == "@LIBEXECDIR@/ready-set-set-root-password";

    if (actionMatches) {
        if (subject.local)
            return polkit.Result.YES;
        else
            return polkit.Result.AUTH_ADMIN;
    }

    return;
});
