root = true

[*]
end_of_line = lf
insert_final_newline = true

[*.blp]
indent_style = space
indent_size = 2

[*.vala]
indent_style = space
indent_size = 4
max_line_length = 150

[meson.build]
indent_style = space
indent_size = 2

[*.c]
indent_style = space
indent_size = 2

[*.h]
indent_style = space
indent_size = 2
