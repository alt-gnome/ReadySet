<policyconfig>
   <action id="@SERVICE_NAME@.CopyToUser">
     <description>Copy file or dir to user homedir</description>
     <message>Authentication is required</message>
     <defaults>
       <allow_any>no</allow_any>
       <allow_inactive>no</allow_inactive>
       <allow_active>auth_admin</allow_active>
     </defaults>
   </action>
   <action id="@SERVICE_NAME@.ExecPreHooks">
     <description>Execute ReadySet system pre hooks</description>
     <message>Authentication is required</message>
     <defaults>
       <allow_any>no</allow_any>
       <allow_inactive>no</allow_inactive>
       <allow_active>auth_admin</allow_active>
     </defaults>
   </action>
   <action id="@SERVICE_NAME@.ExecPostHooks">
     <description>Execute ReadySet system post hooks</description>
     <message>Authentication is required</message>
     <defaults>
       <allow_any>no</allow_any>
       <allow_inactive>no</allow_inactive>
       <allow_active>auth_admin</allow_active>
     </defaults>
   </action>
</policyconfig>
